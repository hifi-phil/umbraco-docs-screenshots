# ---------------------------------------------------------------------------
# Node / Playwright
# ---------------------------------------------------------------------------
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# ---------------------------------------------------------------------------
# Claude Code local state
# ---------------------------------------------------------------------------
**/.claude/kanban-state.json
.claude/settings.local.json

# ---------------------------------------------------------------------------
# .NET build output (applies to every Umbraco instance under demo/)
# ---------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
*.userosscache
.vs/

# ---------------------------------------------------------------------------
# Umbraco runtime data (regenerated by unattended install on first run)
# ---------------------------------------------------------------------------
# SQLite database files
**/umbraco/Data/*.sqlite.db
**/umbraco/Data/*.sqlite.db-shm
**/umbraco/Data/*.sqlite.db-wal

# Temp folder (Examine indexes, NuCache, MediaCache, etc.)
**/umbraco/Data/TEMP/

# Packages created from the backoffice
**/umbraco/Data/CreatedPackages/

# Log files
**/umbraco/Logs/

# Media files (uploaded / installed by packages)
**/wwwroot/media/

# JSON schema files generated at build/run time
**/appsettings-schema.json
**/appsettings-schema.*.json
**/umbraco-package-schema.json

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
